agent:
  max_iterations: 20
  tool_timeout: 30
  process_session_max_ttl: 3600
  audit_log_path: "./logs/audit.log"
  workspace_dir: "@workspace/"
  enable_intermediate_status: true

llm:
  provider: "openai"
  base_url: "https://api.openai.com/v1"
  api_key: "sk-..."
  model: "gpt-4o"
  temperature: 0.2
  context_window: 200000
  max_tokens: 32768
  timeout: 60

feishu:
  app_id: "cli_..."
  app_secret: "..."
  receive_mode: "websocket"
  allowed_user_open_id: "ou_..."
  agent_response_timeout: 120
  retry:
    max_attempts: 3
    backoff_base_seconds: 2

memory:
  provider: "sqlite_vec"
  db_path: "./data/memory.db"
  embedding:
    base_url: "https://api.openai.com/v1"
    api_key: "sk-..."
    model: "BAAI/bge-m3"
  retrieval:
    top_k: 3
    score_floor: 0.0

tavily:
  api_key: "tvly-your-dummy-key-here"
